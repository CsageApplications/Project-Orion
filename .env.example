# ─── Orion Environment Variables ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env — only .env.example gets committed.

# ─── Backend ─────────────────────────────────────────────────────────────────
ORION_BACKEND_URL=http://localhost:8080
ORION_WS_URL=ws://localhost:8080/ws

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://orion:password@localhost:5432/orion

# ─── AI / LLM ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-latest

# ─── ElevenLabs TTS ──────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_EXPIRY=7d

# ─── Robot ───────────────────────────────────────────────────────────────────
ROBOT_SERIAL_PORT=/dev/ttyUSB0
ROBOT_BAUD_RATE=115200
JETSON_IP=192.168.1.100

# ─── Smart Home ──────────────────────────────────────────────────────────────
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=

# ─── Frontend ────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws
VITE_APP_NAME=Orion
